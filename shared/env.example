# JellyStack — shared environment variables
# -----------------------------------------------------------------------------
# Copy this file to `.env` at the repo root (or export these variables in your
# shell) before running any `docker compose` command directly. When JellyStack
# is installed through umbrelOS, these are injected automatically and you do
# NOT need to edit anything here.

# -----------------------------------------------------------------------------
# Root directory shared by every JellyStack app. Putting downloads AND media
# under the same root is what makes hard links work between qBittorrent and
# the *arr apps — without that, every import becomes a full file copy.
# -----------------------------------------------------------------------------
# Default on umbrelOS:  /home/umbrel/umbrel/JellyStack
# Override for dev / non-Umbrel setups (e.g. /srv/media, /mnt/data/JellyStack).
JELLYSTACK_ROOT=${UMBREL_ROOT}/JellyStack

# -----------------------------------------------------------------------------
# Linux permissions. PUID/PGID are applied by LinuxServer.io images so that
# files written inside containers stay owned by your host user (avoiding the
# classic "permission denied" after Sonarr moves a file).
# -----------------------------------------------------------------------------
PUID=1000
PGID=1000
UMASK=002

# -----------------------------------------------------------------------------
# Time zone — affects log timestamps and *arr scheduling. Use an IANA tz name.
# -----------------------------------------------------------------------------
TZ=Europe/Paris

# -----------------------------------------------------------------------------
# Mullvad WireGuard — optional, only if you install jellystack-gluetun and
# want torrent traffic routed through the VPN. You can also set these from
# the JellyStack Panel UI (recommended).
# -----------------------------------------------------------------------------
# VPN_SERVICE_PROVIDER=mullvad
# VPN_TYPE=wireguard
# WIREGUARD_PRIVATE_KEY=
# WIREGUARD_ADDRESSES=10.x.x.x/32
# SERVER_CITIES=Amsterdam
